# ── Direct wallet payment mode (simplest setup) ────────────────────────────
# Set this to YOUR wallet address to receive 0.01 RITUAL per subscriber.
# No smart contract needed. Leave blank to use demo mode.
VITE_RECEIVER_ADDRESS=

# ── Full DigestAgent contract mode (advanced) ──────────────────────────────
# Only set this if you have a deployed DigestAgent.sol on Ritual Testnet.
# If set, this takes priority over VITE_RECEIVER_ADDRESS.
VITE_CONTRACT_ADDRESS=

# ── Shared settings ────────────────────────────────────────────────────────
VITE_CHAIN_ID=1979
VITE_RPC_URL=https://rpc.ritualfoundation.org
VITE_SUBSCRIPTION_PRICE_WEI=10000000000000000
VITE_EXPLORER_URL=https://explorer.ritualfoundation.org
VITE_WALLETCONNECT_PROJECT_ID=
